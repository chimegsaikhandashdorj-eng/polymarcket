# ── Weather API Keys ──────────────────────────────────────────────────────────

# Tomorrow.io — https://app.tomorrow.io/development/keys
TOMORROW_API_KEY=your_tomorrow_api_key_here

# WeatherAPI.com — https://www.weatherapi.com/my/ (free: 1M calls/month)
WEATHERAPI_KEY=your_weatherapi_key_here

# Pirate Weather — https://pirateweather.net/en/latest/ (free: 10K calls/month)
PIRATE_WEATHER_KEY=your_pirate_weather_key_here

# MET Norway (Yr.no) — NO KEY NEEDED, ECMWF model, global

# Polymarket wallet private key (only needed for live trading, NOT paper mode)
# Must be a Polygon-compatible EOA private key (hex, no 0x prefix)
POLY_PRIVATE_KEY=your_private_key_here

# Polymarket API credentials (auto-generated on first run in live mode)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Telegram alerts (optional) — leave blank to disable
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message @userinfobot to get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
